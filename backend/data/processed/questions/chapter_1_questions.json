    {'id': 'q_chunk2_003', 'topic': 'Dimensional Analysis', 'sub_concept': 'Checking equations', 'difficulty_level': 0.3, 'question_text': 'Test dimensionally if the equation v^2 = u^2 + 2ax may be correct.', 'options': [], 'correct_option_index': None, 'solution_logic': 'All terms have dimensions L^2 T^-2, so the equation is dimensionally consistent.'
