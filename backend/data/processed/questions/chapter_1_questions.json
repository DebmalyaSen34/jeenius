[
    {'id': 'q_chunk2_001', 'topic': 'Units', 'sub_concept': 'Unit conversion', 'difficulty_level': 0.3, 'question_text': "Young's modulus of steel is 19×10^10 N/m^2. Express it in dyne/cm^2. Here dyne is the CGS unit of force.", 'options': [], 'correct_option_index': None, 'solution_logic': '1 N/m^2 = 10 dyne/cm^2. Therefore 19×10^10 N/m^2 = 19×10^11 dyne/cm^2.'
