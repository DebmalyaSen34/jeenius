    {'id': 'q_chunk2_037', 'topic': 'Unit conversion', 'sub_concept': 'Surface tension units', 'difficulty_level': 0.3, 'question_text': 'The surface tension of water is 72 dyne/cm. Convert it in SI unit.', 'options': [], 'correct_option_index': None, 'solution_logic': '1 dyne/cm = 0.001 N/m, so 72 dyne/cm = 0.072 N/m.'
