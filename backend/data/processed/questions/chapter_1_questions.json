    {'id': 'q_chunk2_035', 'topic': 'Unit conversion', 'sub_concept': 'Power units', 'difficulty_level': 0.3, 'question_text': 'Express the power of a 100 watt bulb in CGS unit.', 'options': [], 'correct_option_index': None, 'solution_logic': '1 W = 10^7 erg/s, so 100 W = 10^9 erg/s.'
