    {'id': 'q_chunk2_028', 'topic': 'Dimensional Analysis', 'sub_concept': 'Dipole moments', 'difficulty_level': 0.5, 'question_text': 'Find the dimensions of (a) electric dipole moment p and (b) magnetic dipole moment M. The defining equations are p = q d and M = I A.', 'options': [], 'correct_option_index': None, 'solution_logic': 'p: M L T^-1 I; M: M L^2 T^-1 I.'
    },
    {'id': 'q_chunk2_029', 'topic': 'Dimensional Analysis', 'sub_concept': 'Quantum', 'difficulty_level': 0.5, 'question_text': "Find the dimensions of Planck's constant h from the equation E = h ν where E is the energy and ν is the frequency.", 'options': [], 'correct_option_index': None, 'solution_logic': 'h = E/ν → M L^2 T^-1.'
